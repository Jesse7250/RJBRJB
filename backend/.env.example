# EduHive backend environment example
# Copy this file to backend/.env and fill in your own secrets.
# Do not commit backend/.env to Git.

# -----------------------------------------------------------------------------
# Runtime providers
# -----------------------------------------------------------------------------
# LLM_PROVIDER:
#   deepseek = use DeepSeek API
#   spark    = use iFlytek Spark API
#   mock     = local demo data, no external LLM call
#   auto     = prefer configured real provider, otherwise fallback
LLM_PROVIDER=deepseek

# GRAPH_BACKEND:
#   memory = built-in demo graph, easiest for local development
#   neo4j  = use Neo4j service
#   auto   = prefer Neo4j when available, otherwise fallback
GRAPH_BACKEND=memory

# -----------------------------------------------------------------------------
# DeepSeek LLM
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# Optional Anthropic-compatible DeepSeek endpoint used by backend service code.
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# -----------------------------------------------------------------------------
# iFlytek Spark LLM, optional fallback
# -----------------------------------------------------------------------------
SPARK_APP_ID=
SPARK_API_KEY=
SPARK_API_SECRET=
SPARK_API_URL=wss://spark-api.xf-yun.com/v4.0/chat
SPARK_DOMAIN=4.0

# -----------------------------------------------------------------------------
# iFlytek TTS
# -----------------------------------------------------------------------------
SPARK_TTS_APP_ID=your_iflytek_tts_app_id
SPARK_TTS_API_KEY=your_iflytek_tts_api_key
SPARK_TTS_API_SECRET=your_iflytek_tts_api_secret

# Use the endpoint enabled in your iFlytek console.
# General TTS example:
SPARK_TTS_API_URL=wss://tts-api.xfyun.cn/v2/tts

# Some private/premium iFlytek TTS services require an API password.
# Leave empty when your service only uses app_id/api_key/api_secret.
SPARK_TTS_API_PASSWORD=

# -----------------------------------------------------------------------------
# Neo4j graph store, only needed when GRAPH_BACKEND=neo4j
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./eduhive.db
RESOURCE_CACHE_TTL_HOURS=168

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
SECRET_KEY=change_this_secret_key_before_production
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
