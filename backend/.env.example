# 智慧伴学 EduMate 后端环境变量模板
# 使用方法：
# 1. 复制为 backend/.env
# 2. 将 your_* 替换为自己的真实配置
# 3. 不要提交 backend/.env

# -----------------------------------------------------------------------------
# 服务提供方
# -----------------------------------------------------------------------------
# LLM_PROVIDER:
#   deepseek = 使用 DeepSeek API
#   spark    = 使用讯飞星火 API
#   mock     = 使用本地演示生成，不调用外部大模型
#   auto     = 优先使用已配置的真实服务，失败时走降级逻辑
LLM_PROVIDER=deepseek

# GRAPH_BACKEND:
#   memory = 使用内置知识图谱，适合本地演示
#   neo4j  = 使用 Neo4j
#   auto   = 优先连接 Neo4j，失败时降级到内置知识图谱
GRAPH_BACKEND=memory

# -----------------------------------------------------------------------------
# DeepSeek 大模型
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# DeepSeek Anthropic-compatible endpoint，部分服务代码会读取该字段。
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# -----------------------------------------------------------------------------
# 讯飞星火大模型，可选
# -----------------------------------------------------------------------------
SPARK_APP_ID=
SPARK_API_KEY=
SPARK_API_SECRET=
SPARK_API_URL=wss://spark-api.xf-yun.com/v4.0/chat
SPARK_DOMAIN=4.0

# -----------------------------------------------------------------------------
# 讯飞语音合成 TTS
# -----------------------------------------------------------------------------
SPARK_TTS_APP_ID=your_iflytek_tts_app_id
SPARK_TTS_API_KEY=your_iflytek_tts_api_key
SPARK_TTS_API_SECRET=your_iflytek_tts_api_secret

# 填写你在讯飞控制台实际开通的 TTS 地址。
# 通用语音合成示例：
SPARK_TTS_API_URL=wss://tts-api.xfyun.cn/v2/tts

# 私有/超拟人等服务可能需要 API_PASSWORD；普通 app_id/api_key/api_secret 服务可留空。
SPARK_TTS_API_PASSWORD=

# -----------------------------------------------------------------------------
# Neo4j 知识图谱，仅 GRAPH_BACKEND=neo4j 时需要
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# -----------------------------------------------------------------------------
# SQLite 数据库与缓存
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./edumate.db
RESOURCE_CACHE_TTL_HOURS=168

# -----------------------------------------------------------------------------
# 应用配置
# -----------------------------------------------------------------------------
SECRET_KEY=change_this_secret_key_before_production
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
