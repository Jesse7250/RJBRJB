# DeepSeek API 配置（默认使用）
# 文档：https://platform.deepseek.com/api-docs/
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 讯飞星火 API 配置（备用）
# 请前往 https://xinghuo.xfyun.cn/ 申请 API Key
SPARK_APP_ID=
SPARK_API_KEY=
SPARK_API_SECRET=
SPARK_API_URL=wss://spark-api.xf-yun.com/v4.0/chat
SPARK_DOMAIN=4.0

# TTS 配置（可选）
SPARK_TTS_APP_ID=
SPARK_TTS_API_KEY=
SPARK_TTS_API_SECRET=

# Neo4j 配置
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=eduhive123

# SQLite 配置
DATABASE_URL=sqlite:///./eduhive.db

# 应用配置
SECRET_KEY=eduhive-secret-key-change-in-production
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# LLM 提供者：deepseek / spark / mock / auto
LLM_PROVIDER=deepseek
